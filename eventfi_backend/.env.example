# ─────────────────────────────────────────────────────────────
#  EventFi Backend — Environment Variables
#  Copy this file → rename to .env → fill in real values
#  NEVER commit the real .env file to GitHub
# ─────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas (Free Tier) ───────────────────────────────
# Steps:
#  1. Go to cloud.mongodb.com
#  2. Create free cluster (M0 Sandbox)
#  3. Click Connect → Drivers → copy the URI
#  4. Replace <username> <password> with your DB user credentials
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventfi

# ─── JWT ─────────────────────────────────────────────────────
# Use any long random string — keep secret
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Firebase Admin SDK ──────────────────────────────────────
# Steps:
#  1. Firebase Console → Project Settings → Service Accounts
#  2. Click "Generate new private key" → download JSON
#  3. Copy values from that JSON into below fields
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Nodemailer (Gmail SMTP — Free) ──────────────────────────
# Steps:
#  1. Go to myaccount.google.com → Security → App Passwords
#  2. Create an App Password for "Mail"
#  3. Use that 16-character password below (NOT your Gmail password)
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ─── Razorpay (Test Mode — Free) ─────────────────────────────
# Steps:
#  1. Sign up at razorpay.com (free)
#  2. Go to Settings → API Keys → Generate Test Mode Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Cloudinary (Free Tier — 25 GB) ─────────────────────────
# Steps:
#  1. Sign up at cloudinary.com (free, no credit card)
#  2. Go to Dashboard → copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@eventfi.com
